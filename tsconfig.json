{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "out",
    "target": "es2021", // Node.js 16 supports ES2021
    "lib": ["es2021"],
    "module": "Node16",
    "sourceMap": true,
    "allowJs": false,
    "declaration": true,
    "declarationDir": "./out",
    "moduleResolution": "node16",
    "forceConsistentCasingInFileNames": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "ignoreDeprecations": "5.0",
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "exclude": ["out", "node_modules", ".vscode-test", "mocked_data"]
}
